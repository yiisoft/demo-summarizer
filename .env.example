# Local environment configuration.
# Copy this file to .env and adjust as needed.
# In production, set environment variables via server or container configuration instead.
APP_ENV=dev
APP_DEBUG=true

# Default development processing mode.
QUEUE_DRIVER=amqp
WORKERS=2
EXTRACTOR_ADAPTER=kreuzberg
LLM_ADAPTER=llamacpp

# Queue alternatives.
# QUEUE_DRIVER=sync
# QUEUE_DRIVER=redis

# Storage defaults use the included Garage S3-compatible service.
DOCUMENT_STORAGE_DRIVER=s3
S3_ENDPOINT=http://garage:3900
S3_REGION=garage
S3_BUCKET=documents
S3_ACCESS_KEY=GKdemo000000000000000000000000000000
S3_SECRET_KEY=garage-demo-secret-key-000000000000000000000000000000
S3_PATH_STYLE=true

# Summary alternatives.
# LLM_ADAPTER=mock

# Local llama.cpp summaries through the included Docker service.
LLM_BASE_URL=http://llama:8080/v1
LLM_MODEL=SmolLM2-135M-Instruct-Q4_K_M
LLAMA_CPP_HF_REPO=bartowski/SmolLM2-135M-Instruct-GGUF:Q4_K_M
# LLAMA_CPP_MODEL=/models/model.gguf
# LLAMA_CPP_MODEL_URL=https://example.com/model.gguf
LLAMA_CPP_CTX_SIZE=2048
LLAMA_CPP_PARALLEL=2
LLAMA_CPP_N_PREDICT=512
