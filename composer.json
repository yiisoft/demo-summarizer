{
    "name": "yiisoft/app",
    "type": "project",
    "description": "Yii3 web application template",
    "keywords": [
        "yii3",
        "app"
    ],
    "license": "BSD-3-Clause",
    "support": {
        "issues": "https://github.com/yiisoft/app/issues?state=open",
        "source": "https://github.com/yiisoft/app",
        "forum": "https://www.yiiframework.com/forum/",
        "wiki": "https://www.yiiframework.com/wiki/",
        "irc": "ircs://irc.libera.chat:6697/yii",
        "chat": "https://t.me/yii3en"
    },
    "funding": [
        {
            "type": "opencollective",
            "url": "https://opencollective.com/yiisoft"
        },
        {
            "type": "github",
            "url": "https://github.com/sponsors/yiisoft"
        }
    ],
    "repositories": [
        {
            "type": "path",
            "url": "/queue",
            "options": {
                "symlink": true,
                "reference": "none",
                "versions": {
                    "yiisoft/queue": "dev-local"
                }
            }
        },
        {
            "type": "path",
            "url": "/queue-amqp",
            "options": {
                "symlink": true,
                "reference": "none",
                "versions": {
                    "yiisoft/queue-amqp": "dev-local"
                }
            }
        },
        {
            "type": "path",
            "url": "/queue-redis",
            "options": {
                "symlink": true,
                "reference": "none",
                "versions": {
                    "yiisoft/queue-redis": "dev-local"
                }
            }
        }
    ],
    "scripts": {
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@php ./yii serve"
        ],
        "test": "codecept run"
    },
    "require": {
        "php": "8.2 - 8.5",
        "aws/aws-sdk-php": "^3.384",
        "ext-filter": "*",
        "ext-mbstring": "*",
        "ext-pdo_sqlite": "*",
        "ext-redis": "*",
        "ext-sockets": "*",
        "httpsoft/http-message": "^1.1.6",
        "league/flysystem": "^3.34",
        "league/flysystem-aws-s3-v3": "^3.34",
        "league/flysystem-local": "^3.31",
        "php-amqplib/php-amqplib": "^3.7",
        "psr/container": "^2.0.2",
        "psr/http-factory": "^1.1",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0.2",
        "psr/log": "^3.0.2",
        "yiisoft/aliases": "^3.1.1",
        "yiisoft/assets": "^5.1.2",
        "yiisoft/config": "^1.6.2",
        "yiisoft/csrf": "^2.2.3",
        "yiisoft/db": "^2.0",
        "yiisoft/db-migration": "^2.0",
        "yiisoft/db-sqlite": "^2.0",
        "yiisoft/definitions": "^3.4.1",
        "yiisoft/di": "^1.4.1",
        "yiisoft/error-handler": "^4.3.2",
        "yiisoft/html": "^4",
        "yiisoft/http": "^1.3",
        "yiisoft/input-http": "^1.0.1",
        "yiisoft/log": "^2.2.0",
        "yiisoft/middleware-dispatcher": "^5.4",
        "yiisoft/queue": "dev-local as dev-master",
        "yiisoft/queue-amqp": "dev-local as dev-master",
        "yiisoft/queue-redis": "dev-local as dev-master",
        "yiisoft/request-provider": "^1.3",
        "yiisoft/router": "^4.0.2",
        "yiisoft/router-fastroute": "^4.0.3",
        "yiisoft/session": "^3.0.1",
        "yiisoft/validator": "^2.6",
        "yiisoft/view": "^12.2.4",
        "yiisoft/yii-http": "^1.1.1",
        "yiisoft/yii-runner-console": "^2.2.1",
        "yiisoft/yii-runner-http": "^3.2.1",
        "yiisoft/yii-view-renderer": "^7.4.1"
    },
    "require-dev": {
        "ext-dom": "*",
        "vlucas/phpdotenv": "^5.6",
        "codeception/c3": "^2.9",
        "codeception/codeception": "^5.3.5",
        "codeception/module-asserts": "^3.3.0",
        "codeception/module-cli": "^2.0.1",
        "codeception/module-phpbrowser": "^4",
        "friendsofphp/php-cs-fixer": "^3.94.2",
        "guzzlehttp/psr7": "^2.11",
        "phpunit/phpunit": "^11.5.55",
        "rector/rector": "^2.3.9",
        "shipmonk/composer-dependency-analyser": "^1.8.4",
        "vimeo/psalm": "^6.16.1",
        "yiisoft/cache": "^3.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests"
        }
    },
    "extra": {
        "config-plugin-file": "config/configuration.php"
    },
    "config": {
        "sort-packages": true,
        "bump-after-update": true,
        "allow-plugins": {
            "yiisoft/config": true,
            "codeception/c3": true,
            "composer/installers": true
        }
    }
}
